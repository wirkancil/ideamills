# Copy file ini ke .env.production dan isi dengan nilai asli
# JANGAN commit .env.production ke git

OPENROUTER_API_KEY=sk-or-...
USEAPI_TOKEN=user:xxxxx-...
USEAPI_GOOGLE_EMAIL=your@gmail.com
CAPSOLVER_API_KEY=CAP-...

# MongoDB — dihandle otomatis oleh docker-compose (service mongo)
# Jangan ubah baris ini jika pakai docker-compose
MONGODB_URI=mongodb://mongo:27017/ideamills
MONGODB_BUCKET=images

NEXT_PUBLIC_APP_URL=http://YOUR_SERVER_IP:4000
STORAGE_PATH=./storage
