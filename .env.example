# ===================================
# IdeaMills — Environment Variables
# Copy ke .env.local dan isi dengan nilai asli
# ===================================

# OpenRouter — single gateway untuk semua LLM calls
# Dapatkan di: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# useapi.net — Google Flow Veo video generation
# Dapatkan di: https://useapi.net/dashboard
USEAPI_TOKEN=user:xxxxx-...
USEAPI_GOOGLE_EMAIL=your@gmail.com

# MongoDB — local instance
MONGODB_URI=mongodb://127.0.0.1:27017/ideamills
MONGODB_BUCKET=images

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
STORAGE_PATH=./storage

# Dev: LAN access — tambahkan IP mesin development kamu jika akses dari HP/device lain di jaringan yang sama
# Format: comma-separated, misal: 10.10.20.79:3000,10.10.20.82:3000
# Jika tidak diset, semua subnet private (10.x, 172.16-31.x, 192.168.x) otomatis diizinkan
# ALLOWED_DEV_ORIGINS=
