{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {}
  },
  "include": [
    "worker/**/*.ts",
    "scripts/**/*.ts",
    "app/lib/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
